{
  "version": 2,
  "builds": [
    {
      "src": "backend/core/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next",
      "config": {
        "outputDirectory": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/backend/core/wsgi.py"
    },
    {
      "src": "/api/jobs/(.*)",
      "dest": "/backend/core/wsgi.py"
    },
    {
      "src": "/api/ai/(.*)",
      "dest": "/backend/core/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/backend/core/wsgi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/backend/core/wsgi.py"
    },
    {
      "src": "/media/(.*)",
      "dest": "/backend/core/wsgi.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
