# Backend Settings
DEBUG=True
SECRET_KEY=django-insecure-hiremind-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, switch to Postgres for production)
DATABASE_URL=sqlite:///db.sqlite3

# Redis & Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Job API Keys (Free Tiers) ──────────────────────────────────────────────────
# Adzuna: https://developer.adzuna.com/ — 250 req/day free
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Jooble: https://jooble.org/api/index.html — free tier available
JOOBLE_API_KEY=your_jooble_key

# ── Fully Free (no key needed) ─────────────────────────────────────────────────
# Remotive:  https://remotive.com/api/remote-jobs  (no key required)
# Arbeitnow: https://www.arbeitnow.com/api/job-board-api (no key required)
# The Muse:  https://www.themuse.com/api/public/jobs   (no key required)
# RemoteOK:  https://remoteok.com/api                  (no key required)

# AI Features
OPENAI_API_KEY=your_openai_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
